{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top 10 nationalities of Formula 1 drivers across the sport's history, with Australia highlighted",
  "width": 400,
  "height": 280,
  "background": "transparent",
  "data": {
    "values": [
      {"nation": "British",    "count": 162},
      {"nation": "American",   "count": 158},
      {"nation": "Italian",    "count": 99},
      {"nation": "French",     "count": 73},
      {"nation": "German",     "count": 51},
      {"nation": "Brazilian",  "count": 30},
      {"nation": "Argentine",  "count": 26},
      {"nation": "Australian", "count": 17},
      {"nation": "Swiss",      "count": 16},
      {"nation": "Finnish",    "count": 15}
    ]
  },
  "mark": {"type": "bar", "cornerRadiusEnd": 3},
  "encoding": {
    "y": {
      "field": "nation",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {"labelColor": "#cccccc", "labelFontSize": 12}
    },
    "x": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of F1 Drivers",
      "axis": {"labelColor": "#888888", "titleColor": "#777777", "gridColor": "#1e1e1e"}
    },
    "color": {
      "condition": {"test": "datum.nation === 'Australian'", "value": "#E10600"},
      "value": "#333333"
    },
    "tooltip": [
      {"field": "nation", "title": "Nationality"},
      {"field": "count",  "title": "F1 Drivers (all-time)"}
    ]
  },
  "config": {"view": {"stroke": "transparent"}}
}
